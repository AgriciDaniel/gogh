{
  "collapse-filter": false,
  "search": "path:wiki",
  "showTags": false,
  "showAttachments": false,
  "hideUnresolved": true,
  "showOrphans": false,
  "colorGroups": [
    {
      "query": "file:wiki/hot.md OR file:wiki/index.md OR file:wiki/overview.md OR file:wiki/log.md OR path:wiki/meta",
      "color": {
        "a": 1,
        "rgb": 743376
      }
    },
    {
      "query": "path:references/canon",
      "color": {
        "a": 1,
        "rgb": 13886461
      }
    },
    {
      "query": "path:wiki/concepts",
      "color": {
        "a": 1,
        "rgb": 1733608
      }
    },
    {
      "query": "path:wiki/flows",
      "color": {
        "a": 1,
        "rgb": 14233637
      }
    },
    {
      "query": "path:wiki/sources",
      "color": {
        "a": 1,
        "rgb": 2002494
      }
    },
    {
      "query": "path:wiki/decisions",
      "color": {
        "a": 1,
        "rgb": 16362240
      }
    },
    {
      "query": "path:wiki/deliverables OR path:wiki/reports",
      "color": {
        "a": 1,
        "rgb": 16437967
      }
    },
    {
      "query": "path:wiki/entities OR path:wiki/accounts OR path:wiki/platforms",
      "color": {
        "a": 1,
        "rgb": 13560534
      }
    },
    {
      "query": "path:wiki/experiments",
      "color": {
        "a": 1,
        "rgb": 16707523
      }
    }
  ],
  "showArrow": true,
  "textFadeMultiplier": 0.2,
  "nodeSizeMultiplier": 1.25,
  "lineSizeMultiplier": 1.25,
  "centerStrength": 0.5,
  "repelStrength": 11,
  "linkDistance": 155
}
